---
import { getSection } from '../../lib/content'
const { title, text, amount_1, label_1, amount_2, label_2, amount_3, label_3 } = getSection('donaciones')
---

<section id="donaciones">
  <div class="container">
    <div class="donaciones-content fade-in">
      <div class="section-label" style="color: var(--gold);">Donaciones</div>
      <h2 class="section-title light">{title || 'Si te interesa aportar a esta causa'}</h2>
      <p>{text || 'Apoya nuestras sucursales para seguir ayudando a personas que realmente necesitan rehabilitar y perseverar en su vida. Te agradecemos cualquier aporte mensual que quieras realizar.'}</p>
      <div class="donaciones-options">
        <div class="donacion-option">
          <div class="amount">${amount_1 || '5.000'}</div>
          <span>{label_1 || 'Apoyo básico'}</span>
        </div>
        <div class="donacion-option">
          <div class="amount">${amount_2 || '10.000'}</div>
          <span>{label_2 || 'Apoyo mensual'}</span>
        </div>
        <div class="donacion-option">
          <div class="amount">${amount_3 || '25.000'}</div>
          <span>{label_3 || 'Apoyo completo'}</span>
        </div>
      </div>
      <a href="#" class="btn btn-primary" style="margin-top: 32px;">Donar ahora</a>
    </div>
  </div>
</section>

<style>
  #donaciones { background: linear-gradient(135deg, var(--green-900), var(--green-800)); text-align: center; }
  .donaciones-content { max-width: 600px; margin: 0 auto; }
  .donaciones-content p { color: rgba(255,255,255,0.7); margin-bottom: 32px; line-height: 1.7; }
  .donaciones-options { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .donacion-option {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--radius); padding: 32px 28px;
    min-width: 180px; transition: var(--transition); cursor: pointer;
  }
  .donacion-option:hover { background: rgba(255,255,255,0.1); transform: translateY(-4px); }
  .donacion-option .amount { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 700; color: var(--gold); }
  .donacion-option span { display: block; color: rgba(255,255,255,0.5); font-size: 0.8rem; margin-top: 8px; }
</style>
