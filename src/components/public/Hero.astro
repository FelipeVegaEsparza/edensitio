---
import { getSection, getSectionImages } from '../../lib/content'
const {
  badge, title, subtitle,
  stats_years, stats_years_label,
  stats_lives, stats_lives_label,
  stats_centers, stats_centers_label,
} = getSection('hero')
const displayImages = getSectionImages('hero')
const isCarousel = displayImages.length > 1
---

<section class="hero" id="inicio">
  <div class="hero-pattern"></div>
  <div class="hero-content">
    <div class="hero-text fade-in">
      <div class="badge">{badge || 'Centro de Rehabilitación'}</div>
      <h1>{title || 'Fundación El Edén'}</h1>
      <p class="subtitle">{subtitle || 'Preocupados por rehabilitarte. Una comunidad cristiana de tratamiento y restauración para quienes buscan una nueva oportunidad.'}</p>
      <div class="hero-buttons">
        <a href="#servicios" class="btn btn-primary">Conoce nuestros servicios</a>
        <a href="#donaciones" class="btn btn-outline">Quiero ayudar</a>
      </div>
    </div>
    <div class="hero-visual fade-in">
      {displayImages.length > 0 ? (
        <div class="hero-image-wrapper" data-carousel={isCarousel ? 'true' : 'false'}>
          {displayImages.map((img, i) => (
            <img
              src={img.filename}
              alt={img.alt || 'Fundación El Edén'}
              class="hero-image"
              data-index={i}
              style={{ display: i === 0 ? 'block' : 'none' }}
            />
          ))}
          {isCarousel && (
            <>
              <button class="carousel-btn carousel-prev" id="carouselPrev">‹</button>
              <button class="carousel-btn carousel-next" id="carouselNext">›</button>
              <div class="carousel-dots" id="carouselDots">
                {displayImages.map((_, i) => (
                  <span class={`carousel-dot${i === 0 ? ' active' : ''}`} data-index={i}></span>
                ))}
              </div>
            </>
          )}
        </div>
      ) : (
        <div class="hero-circle">
          <div class="hero-circle-inner">
            <div class="icon-leaf">🌿</div>
            <strong>Nueva Vida</strong>
            <p>Restauración y esperanza</p>
          </div>
        </div>
      )}
    </div>
  </div>
  <div class="hero-stats">
    <div class="hero-stat">
      <strong>+{stats_years || '15'}</strong>
      <span>{stats_years_label || 'Años de experiencia'}</span>
    </div>
    <div class="hero-stat">
      <strong>+{stats_lives || '500'}</strong>
      <span>{stats_lives_label || 'Vidas transformadas'}</span>
    </div>
    <div class="hero-stat">
      <strong>{stats_centers || '3'}</strong>
      <span>{stats_centers_label || 'Centros'}</span>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    background: linear-gradient(135deg, var(--green-900) 0%, var(--green-800) 40%, #0a1f12 100%);
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 20% 80%, rgba(212,168,83,0.08) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 80% 20%, rgba(46,204,113,0.06) 0%, transparent 60%);
    z-index: 1;
  }
  .hero-pattern {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.02'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    opacity: 0.15;
    z-index: 1;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 24px 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .hero-text .badge {
    display: inline-block;
    background: rgba(212,168,83,0.15);
    color: var(--gold-light);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 8px 20px;
    border-radius: 50px;
    margin-bottom: 24px;
    border: 1px solid rgba(212,168,83,0.2);
  }
  .hero-text h1 {
    font-size: clamp(2.8rem, 5vw, 4.5rem);
    color: var(--white);
    margin-bottom: 8px;
    white-space: pre-line;
  }
  .hero-text h1 span { color: var(--gold); font-style: italic; }
  .hero-text .subtitle {
    font-size: 1.15rem;
    color: rgba(255,255,255,0.7);
    margin-bottom: 40px;
    max-width: 480px;
    line-height: 1.7;
  }
  .hero-buttons { display: flex; gap: 16px; flex-wrap: wrap; }
  .hero-visual { position: relative; display: flex; justify-content: center; align-items: center; }
  .hero-image-wrapper {
    position: relative;
    max-width: 480px;
    width: 100%;
  }
  .hero-image-wrapper[data-carousel="true"] .hero-image {
    animation: fadeIn 0.5s ease;
  }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  .hero-image {
    width: 100%;
    height: 520px;
    object-fit: cover;
    border-radius: 24px;
    border: 1px solid rgba(212,168,83,0.15);
    box-shadow: 0 24px 80px rgba(0,0,0,0.3);
    transition: var(--transition);
  }
  .hero-image:hover {
    transform: scale(1.01);
    border-color: rgba(212,168,83,0.3);
  }
  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px; height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(0,0,0,0.3);
    color: white;
    font-size: 1.4rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
    backdrop-filter: blur(4px);
    z-index: 2;
  }
  .carousel-btn:hover { background: rgba(212,168,83,0.3); border-color: var(--gold); }
  .carousel-prev { left: 12px; }
  .carousel-next { right: 12px; }
  .carousel-dots {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 2;
  }
  .carousel-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: rgba(255,255,255,0.35);
    cursor: pointer;
    transition: var(--transition);
  }
  .carousel-dot.active { background: var(--gold); transform: scale(1.2); }
  .hero-circle {
    width: 400px; height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(46,204,113,0.25), rgba(13,40,24,0.5));
    border: 1px solid rgba(212,168,83,0.15);
    position: relative;
    display: flex; align-items: center; justify-content: center;
  }
  .hero-circle-inner {
    width: 260px; height: 260px;
    border-radius: 50%;
    background: radial-gradient(circle at 40% 40%, rgba(212,168,83,0.2), transparent);
    border: 1px solid rgba(212,168,83,0.1);
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; text-align: center;
    color: var(--white);
    animation: pulseGlow 4s ease-in-out infinite;
  }
  @keyframes pulseGlow {
    0%, 100% { box-shadow: 0 0 20px rgba(212,168,83,0.1); }
    50% { box-shadow: 0 0 60px rgba(212,168,83,0.2); }
  }
  .hero-circle-inner .icon-leaf { font-size: 2.5rem; margin-bottom: 8px; }
  .hero-circle-inner strong { font-family: 'Playfair Display', serif; font-size: 1.3rem; color: var(--gold); }
  .hero-circle-inner p { font-size: 0.85rem; color: rgba(255,255,255,0.6); margin-top: 4px; }
  .hero-stats {
    position: absolute;
    bottom: 40px; left: 50%;
    transform: translateX(-50%);
    display: flex; gap: 48px; z-index: 2;
  }
  .hero-stat { text-align: center; color: rgba(255,255,255,0.7); }
  .hero-stat strong {
    display: block;
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--white);
    font-family: 'Playfair Display', serif;
  }
  .hero-stat span { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; }
  @media (max-width: 968px) {
    .hero-content { grid-template-columns: 1fr; text-align: center; gap: 40px; }
    .hero-text .subtitle { margin: 0 auto 40px; }
    .hero-buttons { justify-content: center; }
    .hero-circle { width: 280px; height: 280px; }
    .hero-circle-inner { width: 200px; height: 200px; }
    .hero-image-wrapper { max-width: 380px; }
    .hero-image { max-width: 380px; height: 380px; }
    .hero-stats { position: relative; bottom: auto; left: auto; transform: none; justify-content: center; margin-top: 40px; }
  }
  @media (max-width: 600px) {
    .hero-stats { gap: 24px; }
    .hero-circle { width: 240px; height: 240px; }
    .hero-circle-inner { width: 180px; height: 180px; }
    .hero-image-wrapper { max-width: 280px; }
    .hero-image { max-width: 280px; height: 280px; }
    .carousel-btn { width: 32px; height: 32px; font-size: 1.1rem; }
  }
</style>

<script>
  (function() {
    const total = document.querySelectorAll('.hero-image[data-index]').length;
    if (total < 2) return;

    let current = 0;
    const imgs = document.querySelectorAll('.hero-image[data-index]');
    const dots = document.querySelectorAll('.carousel-dot');

    function show(index) {
      imgs.forEach((img, i) => {
        img.style.display = i === index ? 'block' : 'none';
      });
      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === index);
      });
      current = index;
    }

    document.getElementById('carouselPrev')?.addEventListener('click', () => {
      show(current === 0 ? total - 1 : current - 1);
    });
    document.getElementById('carouselNext')?.addEventListener('click', () => {
      show(current === total - 1 ? 0 : current + 1);
    });
    dots.forEach(dot => {
      dot.addEventListener('click', () => show(parseInt(dot.dataset.index)));
    });

    let interval = setInterval(() => show(current === total - 1 ? 0 : current + 1), 5000);

    document.querySelector('.hero-image-wrapper')?.addEventListener('mouseenter', () => clearInterval(interval));
    document.querySelector('.hero-image-wrapper')?.addEventListener('mouseleave', () => {
      interval = setInterval(() => show(current === total - 1 ? 0 : current + 1), 5000);
    });
  })();
</script>
