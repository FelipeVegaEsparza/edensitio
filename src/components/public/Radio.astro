---
import { getSection } from '../../lib/content'
const { title, text, status_text, btn_text, btn_url } = getSection('radio')
---

<section id="radio">
  <div class="container">
    <div class="radio-content fade-in">
      <div class="section-label" style="color: var(--gold);">Radio El Edén</div>
      <h2 class="section-title light">{title || 'Estamos online 24/7'}</h2>
      <p class="section-desc light">{text || 'Acompañamos tu proceso de recuperación también a través de nuestra señal radial con contenido edificante.'}</p>
      <div class="radio-player">
        <div class="status">
          <span class="dot"></span>
          {status_text || 'En vivo'}
        </div>
        <a href={btn_url || '#'} class="btn-radio" target="_blank">{btn_text || '🎧 Escuchar ahora'}</a>
      </div>
    </div>
  </div>
</section>

<style>
  #radio { background: var(--green-800); text-align: center; }
  .radio-content { max-width: 600px; margin: 0 auto; }
  .radio-player {
    display: inline-flex; align-items: center; gap: 20px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 50px; padding: 8px 8px 8px 32px; margin-top: 32px;
  }
  .radio-player .status {
    display: flex; align-items: center; gap: 8px;
    color: rgba(255,255,255,0.7); font-size: 0.85rem;
  }
  .radio-player .status .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--green-500);
    animation: blink 1.5s ease-in-out infinite;
  }
  @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
  .radio-player .btn-radio {
    background: var(--gold); color: var(--green-900);
    padding: 12px 28px; border-radius: 50px;
    font-weight: 600; font-size: 0.85rem; transition: var(--transition);
  }
  .radio-player .btn-radio:hover { background: var(--gold-light); }
  @media (max-width: 600px) {
    .radio-player { flex-direction: column; border-radius: var(--radius); padding: 20px; }
  }
</style>
